# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production-only (when DEBUG=False, behind Nginx)
# Comma-separated. Include the public hostname with its scheme.
CSRF_TRUSTED_ORIGINS=https://lmis.bdabharatpur.org,http://lmis.bdabharatpur.org

# Database (PostgreSQL + PostGIS)
DB_NAME=bda_lmis
DB_USER=bda_user
DB_PASSWORD=your-db-password-here
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# File Storage (local filesystem — served by Nginx in production)
MEDIA_ROOT=/app/media

# OpenStreetMap base tiles (no key required)
# Swap to another OSM-compatible {z}/{x}/{y} provider for production traffic
VITE_OSM_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# DMS workflow database (BDA Document Management System).
# Reached via an SSH tunnel from worksserver (see ops/dms-tunnel.service).
# host.docker.internal resolves to the Docker host gateway — backend's
# extra_hosts entry in docker-compose.prod.yml is what makes that work
# on Linux.
DMS_DB_HOST=host.docker.internal
DMS_DB_PORT=3307
DMS_DB_USER=dmsuser
DMS_DB_PASSWORD=your-dms-mysql-password-here
DMS_DB_NAME=dmsworkflow
